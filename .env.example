# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit real keys.

# OpenRouter API key — enables the real LLM chat in Research Copilot.
# Get one at https://openrouter.ai/keys  (the app works without it, using the
# local paper-grounded answerer as a fallback).
OPENROUTER_API_KEY=

# Optional: override the primary model (default: nvidia/nemotron-3-ultra-550b-a55b:free).
# OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# Optional: override the backup model (default: nvidia/nemotron-3-super-120b-a12b:free).
# OPENROUTER_MODEL_BACKUP=nvidia/nemotron-3-super-120b-a12b:free

# Optional: canonical site URL (used in OpenRouter request headers).
# SITE_URL=https://quantum-research-archive.vercel.app
