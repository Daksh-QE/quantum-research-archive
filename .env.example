# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — NEVER commit real keys.

# OpenRouter API key — enables the real LLM chat in Research Copilot.
# Get one at https://openrouter.ai/keys  (the app works without it, using the
# local paper-grounded answerer as a fallback).
OPENROUTER_API_KEY=

# Optional: override the model (defaults to a free Llama model).
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional: canonical site URL (used in OpenRouter request headers).
# SITE_URL=https://quantum-research-archive.vercel.app
